<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/documentsRoot"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_100"
    android:padding="16dp"
    android:fitsSystemWindows="true">

    <!-- Верхняя панель (избранное + фильтр) -->
    <LinearLayout
        android:id="@+id/documentsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="15dp">

        <!-- Кнопка избранного -->
        <ImageView
            android:id="@+id/btnFavorites"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_star_outline"
            app:tint="@color/gray_500"/>

        <!-- Пустой заполнитель -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="" />

        <!-- Кнопка фильтра/сортировки -->
        <ImageView
            android:id="@+id/btnFilter"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:padding="4dp"
            app:tint="@color/gray_500"
            android:text="+"
            android:textSize="24sp"
            android:gravity="center"
            android:textColor="@color/black"/>
    </LinearLayout>

    <!-- Поле поиска -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="15dp"
        android:background="@drawable/bg_search"
        app:queryHint="Поиск по документам..."
        app:iconifiedByDefault="false"
        app:searchIcon="@android:drawable/ic_menu_search"
        app:closeIcon="@android:drawable/ic_menu_close_clear_cancel"
        app:queryBackground="@android:color/transparent"
        app:submitBackground="@android:color/transparent" />

    <!-- Текст, если документы не найдены -->
    <TextView
        android:id="@+id/tvEmptyDocuments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="Документы не найдены"
        android:textColor="@color/gray_500"
        android:textSize="16sp"
        android:visibility="gone" />

    <!-- Список документов -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDocuments"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="16dp" />

</LinearLayout>
